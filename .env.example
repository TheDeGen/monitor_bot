# Required — bot will not start without these
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Alert destinations — comma-separated chat IDs (DMs and/or groups)
# Get a chat ID by running /chatid in the target chat
TELEGRAM_CHAT_IDS=your-chat-id-here
# Legacy single chat ID (still works if TELEGRAM_CHAT_IDS is not set)
# TELEGRAM_CHAT_ID=your-chat-id-here

# Admin user IDs — comma-separated Telegram user IDs
# Only these users can run /config, /set_threshold, /toggle
# Leave empty to allow all users (fine for private-chat-only setups)
ADMIN_USER_IDS=

# Polymarket monitor settings
POLY_THRESHOLD=10000
POLY_MAX_WALLET_AGE_DAYS=90
POLY_MAX_ODDS=0.20

# Pendle monitor settings (comma-separated chain names)
PENDLE_CHAINS=ethereum,arbitrum,bnb,optimism

# Database
DB_PATH=data/monitor.db

# Data retention (hours)
PURGE_HOURS=48

# Optional: Polygonscan API key for wallet age lookups
POLYGONSCAN_API_KEY=your-polygonscan-api-key-here
